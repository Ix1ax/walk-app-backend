# Copy to .env and adjust. docker-compose reads this file automatically.

# Database
DB_NAME=walk
DB_USERNAME=walk
DB_PASSWORD=walk
DB_PORT=5432

# Application
APP_PORT=8080

# JWT (авторизация). В проде ОБЯЗАТЕЛЬНО задать свой секрет ≥32 байт.
# JWT_SECRET=change-me-to-a-long-random-secret-min-32-bytes
# JWT_TTL_HOURS=720

# Geoapify. Get a free key at https://www.geoapify.com/
# GEOAPIFY_API_KEY=your-key-here
